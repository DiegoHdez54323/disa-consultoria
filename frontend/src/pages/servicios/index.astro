---
// src/pages/servicios.astro
import BaseLayout from "../../layouts/BaseLayout.astro";
import ServicesHero from "../../components/services/ServicesHero.astro";
import ProcessSection from "../../components/services/ProcessSection.astro";
import CTASection from "../../components/services/CTASection.astro";
import { ServiceCard3D } from "../../components/services/ServiceCard3D";

// 1. Eliminamos la importación estática
// import { servicesData } from "../data/servicesFull";

// 2. Importamos el servicio de Sanity y los tipos
import { getAllServices } from "../../services/servicesService";
import type { Service } from "../../sanity/types/services";

// 3. Obtenemos los datos (Fetching)
const allServices: Service[] = await getAllServices();
---

<BaseLayout
  title="Servicios | DiSa Consultoría"
  description="Soluciones tecnológicas a medida: Desarrollo Web, Cloud, IA y Consultoría."
>
  <main class="min-h-screen bg-background overflow-hidden">
    <ServicesHero />

    <section class="relative py-24">
      <div class="container mx-auto px-6">
        <div class="max-w-4xl mx-auto text-center mb-16 scroll-reveal">
          <h2
            class="font-orbitron text-3xl lg:text-5xl font-bold text-foreground"
          >
            Nuestros <span class="text-gradient-primary">Servicios</span>
          </h2>
        </div>

        <div class="grid lg:grid-cols-2 xl:grid-cols-3 gap-6">
          {
            /* 4. Usamos 'allServices' (datos reales) en lugar de 'servicesData' */
            allServices.map((service, index) => (
              <ServiceCard3D client:visible service={service} index={index} />
            ))
          }
        </div>
      </div>
    </section>

    <ProcessSection />
    <CTASection />
  </main>
</BaseLayout>
